{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "iPet",
  "version": "0.1.0",
  "identifier": "com.local.ipet",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "iPet",
        "label": "main",
        "width": 440,
        "height": 720,
        "minWidth": 120,
        "minHeight": 140,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
