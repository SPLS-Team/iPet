{
  "type": "function",
  "function": {
    "name": "recent_system_errors",
    "description": "读取近期系统错误/严重事件日志摘要（Windows 事件日志、macOS unified log、Linux journalctl），用于排查系统问题。",
    "parameters": {
      "type": "object",
      "properties": {
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 20,
          "description": "最多返回多少条事件。"
        },
        "sinceHours": {
          "type": "integer",
          "minimum": 1,
          "maximum": 168,
          "default": 24,
          "description": "查询最近多少小时内的错误。"
        }
      },
      "additionalProperties": false
    }
  }
}
