{
  "type": "function",
  "function": {
    "name": "scan_disk",
    "description": "扫描指定目录，按占用大小返回主要子目录和文件。",
    "parameters": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "description": "要扫描的本地目录绝对路径。"
        },
        "max_depth": {
          "type": "integer",
          "minimum": 1,
          "maximum": 12,
          "description": "递归展示深度。"
        },
        "max_children": {
          "type": "integer",
          "minimum": 1,
          "maximum": 64,
          "description": "每层最多返回多少个子节点。"
        }
      },
      "additionalProperties": false
    }
  }
}

