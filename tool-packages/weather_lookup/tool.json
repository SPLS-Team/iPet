{
  "name": "weather_lookup",
  "displayName": "天气查询",
  "description": "查询指定城市的当前天气（温度、体感、湿度、风速、天气描述），使用免 Key 的 wttr.in 服务。",
  "kind": "builtin",
  "enabled": true,
  "builtIn": true,
  "version": "1.0.0",
  "runtime": {
    "type": "rust-builtin",
    "dispatcher": "ToolDispatcher::dispatch_builtin",
    "source": "tool-packages/desktop_tools/rust"
  },
  "parameters": {
    "type": "object",
    "required": ["city"],
    "properties": {
      "city": {
        "type": "string",
        "description": "城市名称，例如 Tokyo、北京。"
      },
      "units": {
        "type": "string",
        "enum": ["c", "f"],
        "default": "c",
        "description": "温度单位：c 摄氏、f 华氏。"
      }
    },
    "additionalProperties": false
  },
  "permissions": ["network"],
  "safety": {
    "readOnly": true,
    "notes": "向 wttr.in 发起一次 HTTPS GET，带超时与响应大小上限，不发送任何 Key。"
  }
}
