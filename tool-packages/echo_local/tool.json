{
  "schemaVersion": 2,
  "name": "echo_local",
  "displayName": "本地回显",
  "description": "把传入的 text 原样返回，演示本地工具（kind=local）的 stdio 协议。",
  "version": "1.0.0",
  "kind": "local",
  "parameters": {
    "type": "object",
    "required": ["text"],
    "properties": {
      "text": { "type": "string", "description": "要回显的文本" }
    }
  },
  "local": {
    "command": "node",
    "args": ["echo_tool.js"],
    "timeoutSecs": 15
  },
  "permissions": ["process.spawn"],
  "enabled": true
}
